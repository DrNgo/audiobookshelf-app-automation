require "xcodeproj"
require "base64"
require "json"

default_platform(:ios)
opt_out_usage

def required_env(name, default = nil)
  value = ENV[name]
  value = default if value.nil? || value.empty?
  raise KeyError, "environment variable #{name} is not set" if value.nil?
  value.strip
end

DEVELOPER_APP_IDENTIFIER      = required_env("DEVELOPER_APP_IDENTIFIER")
# The home/lock-screen widget ships as an app-extension target. Apple requires an extension's bundle
# id to be prefixed by its host app's, so it defaults to "<app id>.widget" derived from the app-id
# secret — never a hardcoded bundle id. Override with DEVELOPER_WIDGET_APP_IDENTIFIER if the portal's
# widget App ID differs. Its App Store profile must carry the shared App Group capability (see APP_GROUP
# below), which the app and widget use to exchange the server URL + token.
WIDGET_APP_IDENTIFIER         = required_env("DEVELOPER_WIDGET_APP_IDENTIFIER", "#{DEVELOPER_APP_IDENTIFIER}.widget")

# The app + widget share data through an App Group. Upstream hardcodes "group.com.audiobookshelf.app";
# rewrite it to one namespaced under this build's bundle id ("group.<app id>") so it belongs to this
# team, overridable via DEVELOPER_APP_GROUP. App Group ids are globally unique across Apple, so the
# upstream default can't be reused under a different team.
UPSTREAM_APP_GROUP            = "group.com.audiobookshelf.app"
APP_GROUP                     = required_env("DEVELOPER_APP_GROUP", "group.#{DEVELOPER_APP_IDENTIFIER}")

APPLE_KEY_ID                  = required_env("APPLE_KEY_ID")
APPLE_ISSUER_ID               = required_env("APPLE_ISSUER_ID")
APPLE_KEY_CONTENT             = required_env("APPLE_KEY_CONTENT")

MATCH_GIT_URL                 = required_env("MATCH_GIT_URL")
MATCH_GIT_BASIC_AUTHORIZATION = required_env("MATCH_GIT_BASIC_AUTHORIZATION")
MATCH_PASSWORD                = required_env("MATCH_PASSWORD")

REPOSITORY_ROOT  = File.expand_path("..", __dir__)
UPSTREAM_ROOT    = File.join(REPOSITORY_ROOT, "upstream")
IOS_PROJECT_ROOT = File.join(UPSTREAM_ROOT, "ios", "App")
XCODEPROJ_PATH   = File.join(IOS_PROJECT_ROOT, "App.xcodeproj")
WORKSPACE_PATH   = File.join(IOS_PROJECT_ROOT, "App.xcworkspace")
APP_TARGET_NAME    = "Audiobookshelf"
WIDGET_TARGET_NAME = "AudiobookshelfWidget"
APP_SCHEME_NAME    = "App"
BUILD_OUTPUT_DIR = File.join(REPOSITORY_ROOT, "build")

def build_api_key
  app_store_connect_api_key(
    key_id: APPLE_KEY_ID,
    issuer_id: APPLE_ISSUER_ID,
    key_content: APPLE_KEY_CONTENT,
    is_key_content_base64: true,
    duration: 1200,
    in_house: false
  )
end

# App Store Connect rejects pre-release suffixes in CFBundleShortVersionString.
def normalize_marketing_version(version)
  version.sub(/\Av/, "").sub(/-(?:alpha|beta|rc)(?:\.\d+)?\z/, "")
end

# The build is pinned to a commit SHA (.upstream-version), not a release tag, so
# the marketing version comes from the checked-out app itself. package.json is
# the source of truth for the app version (e.g. "0.13.0-beta"); TestFlight build
# numbers auto-increment within that normalized version.
def upstream_marketing_version
  package_json_path = File.join(UPSTREAM_ROOT, "package.json")
  unless File.exist?(package_json_path)
    UI.user_error!("#{package_json_path} not found — run scripts/prepare-upstream.sh first")
  end
  raw_version = JSON.parse(File.read(package_json_path))["version"].to_s.strip
  UI.user_error!("no \"version\" in #{package_json_path}") if raw_version.empty?
  normalize_marketing_version(raw_version)
end

# Apply manual App Store signing to one or more targets. `signing_by_target` maps a target name to a
# hash of { bundle_identifier:, team_id:, provisioning_profile_specifier: }. The app AND its widget
# extension must each be signed with their own bundle id + profile.
def apply_signing_overrides(xcodeproj_path, signing_by_target)
  project = Xcodeproj::Project.open(xcodeproj_path)

  signing_by_target.each do |target_name, settings|
    target = project.targets.find { |t| t.name == target_name }
    raise "target #{target_name} not found in #{xcodeproj_path}" if target.nil?

    target.build_configurations.each do |configuration|
      configuration.build_settings["PRODUCT_BUNDLE_IDENTIFIER"]      = settings.fetch(:bundle_identifier)
      configuration.build_settings["DEVELOPMENT_TEAM"]               = settings.fetch(:team_id)
      configuration.build_settings["CODE_SIGN_STYLE"]                = "Manual"
      configuration.build_settings["CODE_SIGN_IDENTITY"]             = "Apple Distribution"
      configuration.build_settings["PROVISIONING_PROFILE_SPECIFIER"] = settings.fetch(:provisioning_profile_specifier)
    end
  end

  project.save
end

# Stamp the same marketing version + build number onto every given target. The widget extension must
# match its host app's CFBundleShortVersionString/CFBundleVersion or App Store Connect rejects the upload.
def apply_version_overrides(xcodeproj_path, marketing_version, build_number, target_names)
  project = Xcodeproj::Project.open(xcodeproj_path)

  target_names.each do |target_name|
    target = project.targets.find { |t| t.name == target_name }
    raise "target #{target_name} not found in #{xcodeproj_path}" if target.nil?

    target.build_configurations.each do |configuration|
      configuration.build_settings["MARKETING_VERSION"]       = marketing_version
      configuration.build_settings["CURRENT_PROJECT_VERSION"] = build_number.to_s
    end
  end

  project.save
end

def xcodeproj_has_target?(xcodeproj_path, target_name)
  Xcodeproj::Project.open(xcodeproj_path).targets.any? { |t| t.name == target_name }
end

# Rewrite the shared App Group id in the checked-out sources from the upstream default to this build's
# group. The id lives in BOTH entitlements files and the Swift constant that reads the shared container,
# and all must agree or the widget can't read what the app writes. Fails loudly if the upstream string
# is gone (upstream renamed it) rather than silently shipping a mismatched group.
def apply_app_group_override(ios_project_root, upstream_app_group, new_app_group)
  return if new_app_group == upstream_app_group

  targets = [
    File.join(ios_project_root, "App", "App.entitlements"),
    File.join(ios_project_root, "AudiobookshelfWidget", "AudiobookshelfWidget.entitlements"),
    File.join(ios_project_root, "Shared", "util", "widget", "WidgetSharedCredentials.swift")
  ]

  rewritten = 0
  targets.each do |path|
    next unless File.exist?(path)
    content = File.read(path)
    next unless content.include?(upstream_app_group)
    File.write(path, content.gsub(upstream_app_group, new_app_group))
    rewritten += 1
  end

  if rewritten.zero?
    UI.user_error!("App Group '#{upstream_app_group}' not found in any of #{targets.join(', ')} — upstream may have renamed it; update UPSTREAM_APP_GROUP.")
  end

  UI.message("Rewrote App Group #{upstream_app_group} -> #{new_app_group} in #{rewritten} file(s)")
end

def ensure_temp_keychain(name, password)
  keychain_path = File.expand_path("~/Library/Keychains/#{name}-db")
  delete_keychain(name: name) if File.exist?(keychain_path)
  create_keychain(
    name: name,
    password: password,
    unlock: true,
    timeout: 3600,
    lock_when_sleeps: false
  )
end

# Build the prepared upstream checkout into build/App.ipa. Shared by the `build`
# lane (gate, no upload) and the `beta` lane (build + upload).
def build_upstream_ipa
  developer_portal_team_id = required_env("DEVELOPER_PORTAL_TEAM_ID")
  temp_keychain_name       = required_env("TEMP_KEYCHAIN_NAME", "fastlane_tmp_keychain")
  temp_keychain_password   = required_env("TEMP_KEYCHAIN_PASSWORD")

  unless File.directory?(UPSTREAM_ROOT)
    UI.user_error!("upstream/ not found — run scripts/prepare-upstream.sh first")
  end

  ensure_temp_keychain(temp_keychain_name, temp_keychain_password)

  api_key = build_api_key

  # The widget extension only exists in newer upstream checkouts. Provision/sign it only when the
  # pinned upstream actually contains the target, so older pins keep building unchanged.
  widget_present = xcodeproj_has_target?(XCODEPROJ_PATH, WIDGET_TARGET_NAME)
  UI.message("AudiobookshelfWidget target #{widget_present ? 'present — will provision + sign it' : 'absent in this upstream pin — skipping widget signing'}")

  app_identifiers = [DEVELOPER_APP_IDENTIFIER]
  app_identifiers << WIDGET_APP_IDENTIFIER if widget_present

  # Provision the app (and, when present, its widget extension). Each needs its own App Store profile;
  # the widget's must carry the shared App Group capability.
  match(
    type: "appstore",
    app_identifier: app_identifiers,
    git_url: MATCH_GIT_URL,
    git_basic_authorization: Base64.strict_encode64(MATCH_GIT_BASIC_AUTHORIZATION),
    readonly: false,
    keychain_name: temp_keychain_name,
    keychain_password: temp_keychain_password,
    api_key: api_key
  )

  # Use the profile names Match actually installed. Apple appends a numeric
  # suffix when a profile with the base name already exists, so the name
  # cannot be assumed from the bundle identifier.
  profile_mapping = lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING]
  app_profile_specifier    = profile_mapping[DEVELOPER_APP_IDENTIFIER]
  widget_profile_specifier = profile_mapping[WIDGET_APP_IDENTIFIER] if widget_present

  signing_by_target = {
    APP_TARGET_NAME => {
      bundle_identifier: DEVELOPER_APP_IDENTIFIER,
      team_id: developer_portal_team_id,
      provisioning_profile_specifier: app_profile_specifier
    }
  }
  version_targets = [APP_TARGET_NAME]
  provisioning_profiles = { DEVELOPER_APP_IDENTIFIER => app_profile_specifier }

  if widget_present
    signing_by_target[WIDGET_TARGET_NAME] = {
      bundle_identifier: WIDGET_APP_IDENTIFIER,
      team_id: developer_portal_team_id,
      provisioning_profile_specifier: widget_profile_specifier
    }
    version_targets << WIDGET_TARGET_NAME
    provisioning_profiles[WIDGET_APP_IDENTIFIER] = widget_profile_specifier
  end

  apply_signing_overrides(XCODEPROJ_PATH, signing_by_target)

  # Namespace the shared App Group under this build's bundle id (only widget-containing pins have it).
  apply_app_group_override(IOS_PROJECT_ROOT, UPSTREAM_APP_GROUP, APP_GROUP) if widget_present

  marketing_version = upstream_marketing_version
  next_build_number = latest_testflight_build_number(
    api_key: api_key,
    app_identifier: DEVELOPER_APP_IDENTIFIER,
    version: marketing_version,
    initial_build_number: 0
  ).to_i + 1

  apply_version_overrides(XCODEPROJ_PATH, marketing_version, next_build_number, version_targets)

  build_app(
    workspace: WORKSPACE_PATH,
    scheme: APP_SCHEME_NAME,
    configuration: "Release",
    export_method: "app-store",
    export_options: {
      provisioningProfiles: provisioning_profiles
    },
    xcargs: "-allowProvisioningUpdates",
    output_directory: BUILD_OUTPUT_DIR,
    output_name: "App.ipa",
    clean: true
  )
ensure
  if temp_keychain_name && File.exist?(File.expand_path("~/Library/Keychains/#{temp_keychain_name}-db"))
    delete_keychain(name: temp_keychain_name)
  end
end

# Upload an already-built build/App.ipa to TestFlight. The build number and
# version are baked into the .ipa at build time, so this needs no checkout,
# keychain, or upstream sources — only the App Store Connect API key.
def upload_built_ipa
  upstream_ref = required_env("UPSTREAM_TAG")
  ipa_path = File.join(BUILD_OUTPUT_DIR, "App.ipa")

  unless File.exist?(ipa_path)
    UI.user_error!("#{ipa_path} not found — nothing to upload")
  end

  upload_to_testflight(
    api_key: build_api_key,
    app_identifier: DEVELOPER_APP_IDENTIFIER,
    ipa: ipa_path,
    skip_waiting_for_build_processing: true,
    skip_submission: true,
    distribute_external: false,
    notify_external_testers: false,
    changelog: "audiobookshelf-app @ #{upstream_ref[0, 12]}"
  )
end

platform :ios do
  desc "Bootstrap or refresh the App Store distribution certificate and profile via Match."
  lane :certificates do
    temp_keychain_name     = required_env("TEMP_KEYCHAIN_NAME", "fastlane_tmp_keychain")
    temp_keychain_password = required_env("TEMP_KEYCHAIN_PASSWORD")

    ensure_temp_keychain(temp_keychain_name, temp_keychain_password)

    match(
      type: "appstore",
      app_identifier: [DEVELOPER_APP_IDENTIFIER, WIDGET_APP_IDENTIFIER],
      git_url: MATCH_GIT_URL,
      git_basic_authorization: Base64.strict_encode64(MATCH_GIT_BASIC_AUTHORIZATION),
      readonly: false,
      keychain_name: temp_keychain_name,
      keychain_password: temp_keychain_password,
      api_key: build_api_key
    )
  ensure
    if temp_keychain_name && File.exist?(File.expand_path("~/Library/Keychains/#{temp_keychain_name}-db"))
      delete_keychain(name: temp_keychain_name)
    end
  end

  desc "Build the prepared upstream checkout into build/App.ipa (no upload)."
  lane :build do
    build_upstream_ipa
  end

  desc "Upload an already-built build/App.ipa to TestFlight."
  lane :upload do
    upload_built_ipa
  end

  desc "Build the prepared upstream checkout and upload to TestFlight."
  lane :beta do
    build_upstream_ipa
    upload_built_ipa
  end
end
